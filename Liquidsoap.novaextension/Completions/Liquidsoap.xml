	<!-- ==================== SOURCE FUNCTIONS ==================== -->
	<set name="liquidsoap.functions.source" symbol="function">
		<completion string="playlist">
			<behavior>
				<append>($["path/to/playlist"])</append>
			</behavior>
		</completion>
		<completion string="playlist.safe">
			<behavior>
				<append>($["path/to/playlist"])</append>
			</behavior>
		</completion>
		<completion string="single">
			<behavior>
				<append>($["file.mp3"])</append>
			</behavior>
		</completion>
		<completion string="blank">
			<behavior>
				<append>(duration=$[1.])</append>
			</behavior>
		</completion>
		<completion string="sine">
			<behavior>
				<append>($[440.])</append>
			</behavior>
		</completion>
		<completion string="noise">
			<behavior>
				<append>()</append>
			</behavior>
		</completion>
		<completion string="request.create">
			<behavior>
				<append>($["uri"])</append>
			</behavior>
		</completion>
		<completion string="request.queue">
			<behavior>
				<append>()</append>
			</behavior>
		</completion>
	</set>

	<!-- ==================== MIXING / SWITCHING ==================== -->
	<set name="liquidsoap.functions.mixing" symbol="function">
		<completion string="fallback">
			<behavior>
				<append>(track_sensitive=$[true], [
  $[sources]
])</append>
			</behavior>
		</completion>
		<completion string="switch">
			<behavior>
				<append>(track_sensitive=$[true], [
  ({$[condition]}, $[source])
])</append>
			</behavior>
		</completion>
		<completion string="sequence">
			<behavior>
				<append>([
  $[sources]
])</append>
			</behavior>
		</completion>
		<completion string="add">
			<behavior>
				<append>([
  $[sources]
])</append>
			</behavior>
		</completion>
		<completion string="mux_audio">
			<behavior>
				<append>(audio=$[audio_source], $[video_source])</append>
			</behavior>
		</completion>
		<completion string="mux_video">
			<behavior>
				<append>(video=$[video_source], $[audio_source])</append>
			</behavior>
		</completion>
		<completion string="rotate">
			<behavior>
				<append>([
  $[sources]
])</append>
			</behavior>
		</completion>
		<completion string="random">
			<behavior>
				<append>([
  $[sources]
])</append>
			</behavior>
		</completion>
	</set>

	<!-- ==================== AUDIO EFFECTS ==================== -->
	<set name="liquidsoap.functions.effects" symbol="function">
		<completion string="crossfade">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
		<completion string="fade.in">
			<behavior>
				<append>(duration=$[3.], $[source])</append>
			</behavior>
		</completion>
		<completion string="fade.out">
			<behavior>
				<append>(duration=$[3.], $[source])</append>
			</behavior>
		</completion>
		<completion string="amplify">
			<behavior>
				<append>($[1.], $[source])</append>
			</behavior>
		</completion>
		<completion string="normalize">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
		<completion string="compress">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
		<completion string="audio_to_stereo">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
		<completion string="mean">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
		<completion string="swap">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
		<completion string="nrj">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
	</set>

	<!-- ==================== CALLBACKS (2.4.0 method-style) ==================== -->
	<set name="liquidsoap.functions.events" symbol="method">
		<!-- 2.4.0: callbacks are methods on source, synchronous is required -->
		<completion string="on_metadata">
			<behavior>
				<append>(synchronous=$[true], fun (m) -> $[log("New track: #{m['title']}")])</append>
			</behavior>
		</completion>
		<completion string="on_track">
			<behavior>
				<append>(synchronous=$[true], fun (m) -> $[log("Track started")])</append>
			</behavior>
		</completion>
		<completion string="on_end">
			<behavior>
				<append>(synchronous=$[false], delay=$[5.], fun (remaining) -> $[log("Track ending")])</append>
			</behavior>
		</completion>
		<completion string="on_connect">
			<behavior>
				<append>(synchronous=$[true], fun () -> $[log("Connected!")])</append>
			</behavior>
		</completion>
		<completion string="on_disconnect">
			<behavior>
				<append>(synchronous=$[true], fun () -> $[log("Disconnected")])</append>
			</behavior>
		</completion>
		<completion string="on_ready">
			<behavior>
				<append>(synchronous=$[true], fun () -> $[log("Ready")])</append>
			</behavior>
		</completion>
		<!-- 2.4.0: insert_metadata is now a method, not a wrapping operator -->
		<completion string="insert_metadata">
			<behavior>
				<append>([("$[title]", "$[value]")])</append>
			</behavior>
		</completion>
		<completion string="map_metadata">
			<behavior>
				<append>(fun (m) -> $[m])</append>
			</behavior>
		</completion>
		<completion string="strip_blank">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
		<completion string="skip_blank">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
		<completion string="source.skip">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
	</set>

	<!-- ==================== UTILITY FUNCTIONS ==================== -->
	<set name="liquidsoap.functions.util" symbol="function">
		<completion string="log">
			<behavior>
				<append>($["message"])</append>
			</behavior>
		</completion>
		<completion string="print">
			<behavior>
				<append>($["message"])</append>
			</behavior>
		</completion>
		<completion string="log.important">
			<behavior>
				<append>($["message"])</append>
			</behavior>
		</completion>
		<completion string="log.severe">
			<behavior>
				<append>($["message"])</append>
			</behavior>
		</completion>
		<completion string="string.concat">
			<behavior>
				<append>([$[strings]])</append>
			</behavior>
		</completion>
		<completion string="string.contains">
			<behavior>
				<append>(prefix=$["..."], $[str])</append>
			</behavior>
		</completion>
		<completion string="list.hd">
			<behavior>
				<append>($[list])</append>
			</behavior>
		</completion>
		<completion string="list.tl">
			<behavior>
				<append>($[list])</append>
			</behavior>
		</completion>
		<completion string="list.nth">
			<behavior>
				<append>($[list], $[n])</append>
			</behavior>
		</completion>
		<completion string="list.length">
			<behavior>
				<append>($[list])</append>
			</behavior>
		</completion>
		<completion string="list.map">
			<behavior>
				<append>(fun (x) -> $[x], $[list])</append>
			</behavior>
		</completion>
		<completion string="list.iter">
			<behavior>
				<append>(fun (x) -> $[()], $[list])</append>
			</behavior>
		</completion>
		<completion string="list.filter">
			<behavior>
				<append>(fun (x) -> $[true], $[list])</append>
			</behavior>
		</completion>
		<completion string="list.fold">
			<behavior>
				<append>(fun (acc, x) -> $[acc], $[init], $[list])</append>
			</behavior>
		</completion>
		<completion string="list.assoc">
			<behavior>
				<append>($[key], $[list])</append>
			</behavior>
		</completion>
		<completion string="float_of_int">
			<behavior>
				<append>($[n])</append>
			</behavior>
		</completion>
		<completion string="int_of_float">
			<behavior>
				<append>($[x])</append>
			</behavior>
		</completion>
		<completion string="string_of">
			<behavior>
				<append>($[value])</append>
			</behavior>
		</completion>
	</set>

	<!-- ==================== SYSTEM ==================== -->
	<set name="liquidsoap.functions.system" symbol="function">
		<completion string="settings" symbol="variable" />
		<completion string="clock" symbol="variable" />
		<completion string="null" symbol="keyword" />
		<completion string="clock.assign_new">
			<behavior>
				<append>(~id=$["clock"], [$[source]])</append>
			</behavior>
		</completion>
		<completion string="thread.run">
			<behavior>
				<append>($[fun () -> ()])</append>
			</behavior>
		</completion>
		<!-- 2.4.0: cron support -->
		<completion string="cron.add">
			<behavior>
				<append>($["0 * * * *"], fun () ->
  $[log("Cron triggered")]
)</append>
			</behavior>
		</completion>
		<!-- 2.4.0: script path -->
		<completion string="liquidsoap.script.path" symbol="variable" />
		<!-- 2.4.0: loudness -->
		<completion string="normalize_track_gain">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
	</set>

	<!-- ==================== SERVER ==================== -->
	<set name="liquidsoap.functions.server" symbol="function">
		<completion string="server.register">
			<behavior>
				<append>(namespace=$["ns"], $["command"], fun (arg) -> $["response"])</append>
			</behavior>
		</completion>
		<completion string="interactive.float">
			<behavior>
				<append>($["name"], $[0.])</append>
			</behavior>
		</completion>
		<completion string="interactive.bool">
			<behavior>
				<append>($["name"], $[false])</append>
			</behavior>
		</completion>
		<completion string="harbor.http.register">
			<behavior>
				<append>(port=$[8080], $["/"], fun (~protocol, ~data, ~headers, uri) -> $[http.response(data="OK")])</append>
			</behavior>
		</completion>
	</set>

</completions>
