<?xml version="1.0" encoding="UTF-8"?>
<completions>

	<!--
		Unified identifier/dotted completion.

		The expression deliberately captures the ENTIRE dotted path (e.g.
		"output.du") so the matched range covers every character the
		completion string will overwrite. Splitting this into separate
		"identifier" and "method" providers breaks dotted completions like
		"output.dummy": a lookbehind-based method provider does not include
		the dot in the replaceable range, so Nova inserts "output.dummy" on
		top of the already-typed "output.", producing "output.output.dummy".
	-->
	<provider name="identifier">
		<syntax>liquidsoap</syntax>
		<selector>*:not(string,comment)</selector>
		<!--
			The leading `%?` lets the match include the encoder/preprocessor
			sigil (e.g. `%wav`, `%include`). Without it, typing `%w` matches
			only `w`, and Nova inserts `%wav` on top of the typed `%`, giving
			`%%wav`. The lookbehind blocks matching mid-identifier and after a
			dot (so dotted completions stay anchored at the path root).
		-->
		<expression>(?&lt;![\.\w])%?[a-zA-Z_][a-zA-Z0-9_]*(?:\.[a-zA-Z_][a-zA-Z0-9_]*)*</expression>

		<symbols type="function">
			<behavior>
				<arguments prefix="(" suffix=")" separator=", " />
			</behavior>
		</symbols>
		<symbols type="variable,constant,argument,method,property" />

		<set>liquidsoap.keywords</set>
		<set>liquidsoap.types</set>
		<set>liquidsoap.preprocessor</set>
		<set>liquidsoap.encoders</set>
		<set>liquidsoap.functions.output</set>
		<set>liquidsoap.functions.input</set>
		<set>liquidsoap.functions.source</set>
		<set>liquidsoap.functions.mixing</set>
		<set>liquidsoap.functions.effects</set>
		<set>liquidsoap.functions.events</set>
		<set>liquidsoap.functions.util</set>
		<set>liquidsoap.functions.system</set>
		<set>liquidsoap.functions.server</set>
	</provider>

	<!-- ==================== KEYWORDS ==================== -->
	<set name="liquidsoap.keywords" symbol="statement">
		<completion string="let">
			<behavior>
				<append> $[name] = </append>
			</behavior>
		</completion>
		<completion string="def">
			<behavior>
				<append> $[name]($[args])
  $[body]
end</append>
			</behavior>
		</completion>
		<completion string="fun">
			<behavior>
				<append> ($[args]) -> $[body]</append>
			</behavior>
		</completion>
		<completion string="if">
			<behavior>
				<append> $[condition] then
  $[body]
end</append>
			</behavior>
		</completion>
		<completion string="then" />
		<completion string="else" />
		<completion string="elsif">
			<behavior>
				<append> $[condition] then</append>
			</behavior>
		</completion>
		<completion string="end" />
		<completion string="begin" />
		<completion string="for">
			<behavior>
				<append> $[i] = $[start] to $[end] do
  $[body]
end</append>
			</behavior>
		</completion>
		<completion string="to" />
		<completion string="do" />
		<completion string="while">
			<behavior>
				<append> $[condition] do
  $[body]
end</append>
			</behavior>
		</completion>
		<completion string="try">
			<behavior>
				<append>
  $[body]
catch $[err] do
  $[handler]
end</append>
			</behavior>
		</completion>
		<completion string="catch" />
		<completion string="finally" />
		<completion string="open" />
		<completion string="and" />
		<completion string="or" />
		<completion string="not" />
		<completion string="mod" />
		<completion string="rec" />
		<completion string="replaces" />
	</set>

	<!-- ==================== TYPES ==================== -->
	<set name="liquidsoap.types" symbol="type">
		<completion string="int" />
		<completion string="float" />
		<completion string="bool" />
		<completion string="string" />
		<completion string="unit" />
		<completion string="never" />
		<completion string="ref" />
		<completion string="source" />
	</set>

	<!-- ==================== PREPROCESSOR ==================== -->
	<set name="liquidsoap.preprocessor" symbol="statement">
		<completion string="%include" />
		<completion string="%include_extra" />
		<completion string="%ifdef" />
		<completion string="%ifndef" />
		<completion string="%ifversion" />
		<completion string="%ifnversion" />
		<completion string="%ifencoder" />
		<completion string="%ifnencoder" />
		<completion string="%else" />
		<completion string="%endif" />
	</set>

	<!-- ==================== ENCODERS ==================== -->
	<set name="liquidsoap.encoders" symbol="constant">
		<completion string="%mp3" />
		<completion string="%mp3.cbr" />
		<completion string="%mp3.vbr" />
		<completion string="%mp3.abr" />
		<completion string="%fdkaac" />
		<completion string="%vorbis" />
		<completion string="%vorbis.cbr" />
		<completion string="%vorbis.abr" />
		<completion string="%opus" />
		<completion string="%flac" />
		<completion string="%wav" />
		<completion string="%ogg" />
		<completion string="%ffmpeg" />
		<completion string="%external" />
	</set>

	<!-- ==================== OUTPUT FUNCTIONS ==================== -->
	<set name="liquidsoap.functions.output" symbol="function">
		<completion string="output">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
		<completion string="output.icecast">
			<behavior>
				<append>($[%vorbis], host=$["localhost"], port=$[8000], password=$["hackme"], mount=$["/"], $[source])</append>
			</behavior>
		</completion>
		<completion string="output.file">
			<behavior>
				<append>($[%vorbis], $[path], $[source])</append>
			</behavior>
		</completion>
		<completion string="output.harbor">
			<behavior>
				<append>($[%vorbis], mount=$["/"], $[source])</append>
			</behavior>
		</completion>
		<completion string="output.dummy">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
		<completion string="output.pulseaudio">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
		<completion string="output.alsa">
			<behavior>
				<append>($[source])</append>
			</behavior>
		</completion>
		<completion string="output.hls">
			<behavior>
				<append>($[path], $[source])</append>
			</behavior>
		</completion>
		<completion string="output.url">
			<behavior>
				<append>(url=$["rtmp://..."], $[source])</append>
			</behavior>
		</completion>
		<completion string="output.youtube.live">
			<behavior>
				<append>(key=$["stream_key"], $[source])</append>
			</behavior>
		</completion>
	</set>

	<!-- ==================== INPUT FUNCTIONS ==================== -->
	<set name="liquidsoap.functions.input" symbol="function">
		<completion string="input.http">
			<behavior>
				<append>($["http://..."])</append>
			</behavior>
		</completion>
		<completion string="input.harbor">
			<behavior>
				<append>($["/"], port=$[8005])</append>
			</behavior>
		</completion>
		<completion string="input.pulseaudio">
			<behavior>
				<append>()</append>
			</behavior>
		</completion>
		<completion string="input.alsa">
			<behavior>
				<append>()</append>
			</behavior>
		</completion>
		<completion string="input.ffmpeg">
			<behavior>
				<append>($[input_url])</append>
			</behavior>
		</completion>
		<completion string="input.external">
			<behavior>
				<append>($["command"])</append>
			</behavior>
		</completion>
