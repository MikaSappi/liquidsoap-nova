{
    "identifier": "com.mikasappi.liquidsoap",
    "name": "Liquidsoap",
    "organization": "Mika Säppi",
    "description": "Liquidsoap language support for Nova — syntax highlighting, completions, and formatting.",
    "version": "0.1.0",
    "license": "MIT",
    "repository": "https://github.com/savonet/vscode-liquidsoap",
    "categories": ["languages", "formatters", "completions"],

    "main": "Scripts/main.js",

    "entitlements": {
        "process": true,
        "filesystem": "readonly"
    },

    "activationEvents": [
        "onLanguage:liquidsoap"
    ],

    "commands": {
        "editor": [
            {
                "title": "Format Document",
                "command": "liquidsoap.format",
                "shortcut": "opt-shift-f",
                "filters": {
                    "syntaxes": ["liquidsoap"]
                }
            }
        ]
    },

    "config": [
        {
            "key": "liquidsoap.formatOnSave",
            "title": "Format on Save",
            "type": "boolean",
            "default": false
        },
        {
            "key": "liquidsoap.prettierPath",
            "title": "Path to prettier executable",
            "description": "Leave empty to use npx prettier",
            "type": "string",
            "default": ""
        }
    ],

    "configWorkspace": [
        {
            "key": "liquidsoap.formatOnSave",
            "title": "Format on Save",
            "type": "enum",
            "values": ["Global Default", "Enable", "Disable"],
            "default": "Global Default"
        }
    ]
}
